    "voice_commands": {
        "_comment": "Phrase → action. Triggered during the post-paste 10-second commit window, or mid-dictation depending on `phase`.",
        "Enter": {
            "phase": "after",
            "action": "submit"
        },
        "Send": {
            "phase": "after",
            "action": "submit"
        },
